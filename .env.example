# ============================================================
# WhatsApp Reminder Platform - environment configuration
# Copy this file to .env and fill in real values.
# ============================================================

# --- Server ---
PORT=8080
# Comma-separated list of admin API keys allowed to manage users (bootstrap only)
ADMIN_API_KEYS=change-me-admin-key

# --- Storage backend(s) ---
# Which storage backends are active. Comma-separated: "postgres", "sheets", or "postgres,sheets" for both at once.
# When both are enabled, writes go to both (Postgres is treated as the source of truth for reads).
STORAGE_BACKENDS=postgres

# --- PostgreSQL (used if STORAGE_BACKENDS includes "postgres") ---
DATABASE_URL=postgres://reminder_user:reminder_pass@localhost:5432/reminders
PGSSL=false

# --- Google Sheets (used if STORAGE_BACKENDS includes "sheets") ---
# Service account JSON, either as a file path or inline JSON string.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./secrets/service-account.json
# One shared spreadsheet, with tabs: Users, Numbers, Reminders, Templates, DoneReminders
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- WAHA (WhatsApp HTTP API) gateway ---
WAHA_BASE_URL=https://3store.tech
WAHA_API_KEY=change-me-waha-key

# --- ha-whatsapp (https://faserf.github.io/ha-whatsapp/) gateway ---
# Home Assistant instance running the ha-whatsapp custom integration.
# Used only when a user's number is configured with gateway=ha-whatsapp.
HA_BASE_URL=https://3store.tech
HA_LONG_LIVED_TOKEN=change-me-ha-token
# ha-whatsapp exposes its send action as a HA service call, e.g. whatsapp.send_message
HA_WHATSAPP_SERVICE=whatsapp.send_message

# --- Home Assistant webhook notifications (optional, fired after every send) ---
HA_NOTIFY_WEBHOOK_URL=https://3store.tech/api/webhook/reminder_sent

# --- Scheduler ---
# Cron expression for how often to scan for due reminders
SCHEDULER_CRON=*/1 * * * *
# Typing indicator delay before sending (ms), matches original Apps Script behavior
TYPING_DELAY_MS=10000

# --- Footer template default (Handlebars-style {{placeholders}}) ---
DEFAULT_FOOTER_TEMPLATE="\n\n~Auto Reminder~      ~تذكير تلقائي~"
